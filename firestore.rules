
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public collections for content and settings.
    // Anyone can read, but only authenticated admins can write.
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /processingPosts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /processing_logs/{logId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /gear/{gearId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // The DSO cache collection.
    // Anyone can read from the cache.
    // Anyone can write to the cache. This is safe because the data is generated
    // by our trusted Gemini API call within the application code, not by users directly.
    // This allows any user to populate the cache for the benefit of all users.
    match /dso_cache/{cacheId} {
      allow read, write: if true;
    }
  }
}
