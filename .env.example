# AstroCapture — Environment Variables
# Copy this file to .env.local and fill in your API keys

# Gemini API (for AI features)
# Get your key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# IPGeolocation Astronomy API (sun/moon data, twilight times)
# Get your key: https://ipgeolocation.io/
IPGEOLOCATION_API_KEY=

# NASA APOD API (Astronomy Picture of the Day)
# Get your key: https://api.nasa.gov/
# Falls back to DEMO_KEY if empty (rate-limited)
NASA_API_KEY=